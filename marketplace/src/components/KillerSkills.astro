---
import spotlightData from '../data/spotlights.json';

const spotlights = spotlightData.spotlights;
const week = spotlightData.week;
---

<div class="killer-grid">
  {spotlights.map(skill => (
    <div class="killer-card" style="cursor: pointer;" data-href={skill.link} data-slug={skill.pluginSlug} data-week={week}>
      <div class="killer-top">
        <span class="killer-grade">{skill.grade}</span>
        <span class="killer-category">{skill.category}</span>
      </div>
      <h3 class="killer-headline">{skill.headline}</h3>
      <p class="killer-why">{skill.whyKiller}</p>
      <div class="killer-meta">
        <a href={`https://github.com/${skill.authorGithub}`} target="_blank" rel="noopener noreferrer" class="killer-author">
          <img src={`https://github.com/${skill.authorGithub}.png?size=56`} alt={skill.author} class="killer-avatar" width="28" height="28" loading="lazy" />
          {skill.author}
        </a>
        <span class="killer-skills">{skill.skillCount} skills</span>
      </div>
      <span class="killer-cta">View plugin &rarr;</span>
    </div>
  ))}
</div>

<style>
  .killer-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 1.25rem;
    margin-top: 1.5rem;
  }

  .killer-card {
    background: var(--surface-2);
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 1.75rem;
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    transition: transform var(--duration-fast) var(--ease-out),
                border-color var(--duration-fast) var(--ease-out),
                box-shadow var(--duration-normal) var(--ease-out);
    position: relative;
    overflow: hidden;
  }

  /* Always-visible 3px primary gradient top bar */
  .killer-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 3px;
    background: linear-gradient(90deg, var(--primary) 0%, var(--primary-light) 100%);
  }

  .killer-card:hover {
    transform: translateY(-3px);
    border-color: var(--primary-border);
    box-shadow: 0 8px 24px oklch(0% 0 0 / 0.25), 0 0 0 1px var(--primary-tint);
  }

  .killer-top {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .killer-grade {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    background: var(--primary);
    color: white;
    font-family: 'Instrument Sans', system-ui, sans-serif;
    font-size: 1.1rem;
    font-weight: 700;
    border-radius: 8px;
    letter-spacing: 0.02em;
  }

  .killer-category {
    font-family: 'DM Mono', monospace;
    font-size: 0.7rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-2);
    background: var(--surface-3);
    padding: 0.3rem 0.6rem;
    border-radius: 6px;
  }

  .killer-headline {
    font-family: 'Instrument Sans', system-ui, sans-serif;
    font-size: 1.2rem;
    font-weight: 700;
    line-height: 1.2;
    color: var(--text);
    margin: 0;
  }

  .killer-why {
    font-size: 0.9rem;
    line-height: 1.6;
    color: var(--text-2);
    margin: 0;
    flex: 1;
  }

  .killer-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 0.75rem;
    border-top: 1px solid var(--border);
  }

  .killer-author {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.85rem;
    color: var(--text-2);
    text-decoration: none;
    transition: color var(--duration-fast);
  }

  .killer-author:hover {
    color: var(--primary);
  }

  .killer-avatar {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    border: 2px solid var(--primary-border);
  }

  .killer-skills {
    font-family: 'DM Mono', monospace;
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--primary);
    background: var(--primary-tint);
    padding: 0.2rem 0.5rem;
    border-radius: 4px;
  }

  .killer-cta {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--primary);
    transition: letter-spacing var(--duration-fast);
  }

  .killer-card:hover .killer-cta {
    letter-spacing: 0.04em;
  }

  @media (max-width: 768px) {
    .killer-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<script is:inline>
  document.querySelectorAll('.killer-card').forEach(function(card) {
    card.addEventListener('click', function(e) {
      if (e.target.closest('a')) {
        return;
      }
      var slug = card.dataset.slug;
      var week = card.dataset.week;
      if (window.trackEvent) {
        window.trackEvent('killer_skill_click', { slug: slug, week: week });
      }
      if (window.logFirebaseEvent) {
        window.logFirebaseEvent('killer_skill_click', { slug: slug, week: week });
      }
      var href = card.dataset.href;
      if (href) {
        window.location.href = href;
      }
    });
  });
</script>
