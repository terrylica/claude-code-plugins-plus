---
interface Props {
  title: string;
  description?: string;
  image?: string;
}

const { title, description = "Browse 244 searchable agent skills and 259 plugins. Fuzzy search, interactive tutorials, and production-ready tools for Claude Code.", image = "/og-image.png" } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{title}</title>
    <meta name="description" content={description}>
    <meta name="author" content="Intent Solutions IO">
    <meta name="theme-color" content="#5436DA">
    <link rel="canonical" content={`https://tonsofskills.com${Astro.url.pathname}`}>
    <link rel="icon" href="/favicon.svg" type="image/svg+xml">

    <!-- Security Headers -->
    <meta http-equiv="X-Content-Type-Options" content="nosniff">
    <meta http-equiv="X-Frame-Options" content="SAMEORIGIN">
    <meta http-equiv="Referrer-Policy" content="strict-origin-when-cross-origin">

    <!-- Open Graph -->
    <meta property="og:type" content="website">
    <meta property="og:url" content={`https://tonsofskills.com${Astro.url.pathname}`}>
    <meta property="og:title" content={title}>
    <meta property="og:description" content={description}>
    <meta property="og:site_name" content="Claude Code Plugins">
    <meta property="og:image" content={`https://tonsofskills.com${image}`}>
    <meta property="og:image:alt" content={title}>
    <meta property="og:locale" content="en_US">

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:url" content={`https://tonsofskills.com${Astro.url.pathname}`}>
    <meta name="twitter:title" content={title}>
    <meta name="twitter:description" content={description}>
    <meta name="twitter:image" content={`https://tonsofskills.com${image}`}>
    <meta name="twitter:creator" content="@jeremylshore">

    <slot name="head" />

    <!-- Google Analytics -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-9Z1DTMTT44"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-9Z1DTMTT44');
    </script>

    <!-- Firebase Analytics -->
    <script type="module" is:inline define:vars={{ firebaseConfigJson: import.meta.env.PUBLIC_FIREBASE_CONFIG || '{}' }}>
      import { initializeApp } from 'https://www.gstatic.com/firebasejs/11.8.1/firebase-app.js';
      import { getAnalytics, logEvent } from 'https://www.gstatic.com/firebasejs/11.8.1/firebase-analytics.js';

      // Config injected from Secret Manager at build time
      const firebaseConfig = JSON.parse(firebaseConfigJson);

      if (firebaseConfig.apiKey) {
        const app = initializeApp(firebaseConfig);
        const analytics = getAnalytics(app);

        // Log page view with UTM attribution
        const urlParams = new URLSearchParams(window.location.search);
        const pageViewParams = {
          page_path: window.location.pathname,
          page_title: document.title
        };
        const utmSource = urlParams.get('utm_source');
        const utmMedium = urlParams.get('utm_medium');
        if (utmSource) pageViewParams.source = utmSource;
        if (utmMedium) pageViewParams.medium = utmMedium;
        logEvent(analytics, 'page_view', pageViewParams);

        // Make analytics available globally for custom events
        window.firebaseAnalytics = analytics;
        window.logFirebaseEvent = (eventName, params) => logEvent(analytics, eventName, params);
      }
    </script>

    <!-- Unified Analytics Helper -->
    <script is:inline src="/scripts/analytics.js"></script>

    <!-- Fonts: Bebas Neue (display), DM Sans (body), DM Mono (mono/labels) -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&family=DM+Mono:ital,wght@0,400;0,500;1,400&display=swap" rel="stylesheet">

    <style>
        /* ========================================
           BRAVES BOOTH DARK THEME
           ======================================== */
        :root {
            /* Core surface palette */
            --surface:   #06090f;
            --surface-1: #0d1117;
            --surface-2: #161b22;
            --surface-3: #1c2333;

            /* Brand accents */
            --navy:  #0C2340;
            --red:   #CE1141;
            --gold:  #EAAA00;

            /* Borders */
            --border:        #30363d;
            --border-bright: #484f58;

            /* Text */
            --text:   #e6edf3;
            --text-2: #8b949e;
            --text-3: #6e7681;

            /* Status */
            --positive: #3fb950;
            --warning:  #d29922;
            --danger:   #f85149;

            /* ----------------------------------------
               Legacy brand-* aliases — kept so that
               existing pages that reference these vars
               continue to work unchanged.
               ---------------------------------------- */
            --brand-dark:         #06090f;        /* was #141413 → surface */
            --brand-light:        #e6edf3;        /* was #faf9f5 → text */
            --brand-mid-gray:     #8b949e;        /* was #b0aea5 → text-2 */
            --brand-light-gray:   #30363d;        /* was #e8e6dc → border */
            --brand-orange:       #EAAA00;        /* was #d97757 → gold */
            --brand-orange-dark:  #CE1141;        /* was #c45e3e → red */
            --brand-orange-light: #f0c040;        /* was #e8937a → gold lighter */
            --brand-blue:         #4493f8;        /* was #6a9bcc */
            --brand-green:        #3fb950;        /* was #788c5d → positive */

            --transition-smooth: cubic-bezier(0.4, 0, 0.2, 1);
        }

        :global(*), :global(*::before), :global(*::after) {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        :global(html), :global(body) {
            overflow-x: hidden;
            max-width: 100%;
            scroll-behavior: smooth;
            scroll-padding-top: 90px;
        }

        body {
            font-family: 'DM Sans', system-ui, sans-serif;
            background-color: var(--surface-1);
            color: var(--text);
            line-height: 1.7;
        }

        h1, h2 {
            font-family: 'Bebas Neue', Impact, Arial, sans-serif;
            letter-spacing: 0.03em;
        }

        h3, h4, h5, h6 {
            font-family: 'DM Sans', system-ui, sans-serif;
        }

        /* Navigation */
        nav {
            position: fixed;
            top: 0;
            width: 100%;
            padding: 1rem 4rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
            z-index: 100;
            background: var(--navy);
            border-bottom: 1px solid var(--border);
        }

        .logo {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            font-weight: 600;
            font-size: 1.1rem;
            letter-spacing: -0.02em;
            color: var(--text);
            text-decoration: none;
            font-family: 'DM Sans', system-ui, sans-serif;
        }

        .logo-text {
            display: flex;
            flex-direction: column;
            line-height: 1.2;
        }

        .logo-title {
            font-family: 'Bebas Neue', Impact, Arial, sans-serif;
            font-weight: 400;
            font-size: 1.35rem;
            letter-spacing: 0.06em;
            color: var(--gold);
        }

        .logo-subtitle {
            font-size: 0.65rem;
            font-weight: 400;
            color: var(--text-3);
            letter-spacing: 0.02em;
            font-family: 'DM Mono', monospace;
        }

        .logo-icon {
            width: 36px;
            height: 36px;
            background: var(--gold);
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--navy);
            font-weight: 700;
            font-size: 1.2rem;
        }

        .nav-links {
            display: flex;
            gap: 2.5rem;
            list-style: none;
            font-family: 'DM Sans', system-ui, sans-serif;
        }

        .nav-links a {
            color: var(--text-2);
            text-decoration: none;
            font-size: 0.9rem;
            font-weight: 500;
            transition: color 0.3s var(--transition-smooth);
        }

        .nav-links a:hover {
            color: var(--gold);
        }

        .nav-cta {
            background: var(--red) !important;
            color: white !important;
            padding: 0.5rem 1.25rem;
            border-radius: 6px;
            font-weight: 600;
            transition: all 0.3s var(--transition-smooth);
        }

        .nav-cta:hover {
            background: #a50d33 !important;
            color: white !important;
            transform: translateY(-2px);
        }

        /* Mobile Menu */
        .mobile-menu-toggle {
            display: none;
            background: none;
            border: none;
            color: var(--text);
            cursor: pointer;
            padding: 0.5rem;
        }

        .mobile-menu-toggle svg {
            width: 24px;
            height: 24px;
        }

        /* Main Content */
        main {
            padding-top: 72px; /* nav height only — no top banner */
            min-height: calc(100vh - 72px);
        }

        /* Footer */
        footer {
            background: var(--surface);
            color: var(--text-2);
            padding: 3rem 2rem 2rem;
            margin-top: 4rem;
            border-top: 1px solid var(--border);
        }

        .footer-content {
            max-width: 1200px;
            margin: 0 auto;
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 2rem;
            padding-bottom: 2rem;
            border-bottom: 1px solid var(--border);
        }

        .footer-section h4 {
            color: var(--gold);
            font-size: 0.8rem;
            font-weight: 600;
            margin-bottom: 1rem;
            text-transform: uppercase;
            letter-spacing: 0.08em;
            font-family: 'DM Mono', monospace;
        }

        .footer-section ul {
            list-style: none;
        }

        .footer-section a {
            color: var(--text-2);
            text-decoration: none;
            font-size: 0.85rem;
            line-height: 2;
            transition: color 0.3s;
        }

        .footer-section a:hover {
            color: var(--gold);
        }

        .footer-bottom {
            max-width: 1200px;
            margin: 0 auto;
            padding-top: 2rem;
            text-align: center;
            font-size: 0.85rem;
            color: var(--text-3);
        }

        .footer-bottom a {
            color: var(--gold);
            text-decoration: none;
        }

        /* Mobile Styles */
        @media (max-width: 768px) {
            nav {
                padding: 1rem 1.5rem;
            }

            .mobile-menu-toggle {
                display: block;
            }

            .nav-links {
                display: none; /* Hidden by default on mobile to prevent horizontal scroll */
                position: fixed;
                top: 0;
                right: -100%;
                width: 80%;
                max-width: 300px;
                height: 100vh;
                background: var(--surface-1);
                border-left: 1px solid var(--border);
                flex-direction: column;
                gap: 0;
                padding: 5rem 0 2rem;
                transition: right 0.3s var(--transition-smooth);
                overflow-y: auto;
                z-index: 999;
                box-shadow: -4px 0 20px rgba(0, 0, 0, 0.5);
            }

            .nav-links.active {
                display: flex; /* Show when menu is opened */
                right: 0;
            }

            .nav-links li {
                width: 100%;
            }

            .nav-links a {
                display: block;
                padding: 1rem 2rem;
                border-bottom: 1px solid var(--border);
            }

            .nav-cta {
                margin: 1rem 2rem;
                text-align: center;
                display: block;
            }

            main {
                padding-top: 64px; /* nav only on mobile */
            }

            .logo-subtitle {
                display: none; /* Hide on mobile for cleaner look */
            }

            .footer-content {
                grid-template-columns: 1fr;
            }
        }

        /* Prevent body scroll when mobile menu is open */
        body.menu-open {
            overflow: hidden;
        }
    </style>
</head>
<body>
    <!-- Navigation -->
    <nav>
        <a href="/" class="logo">
            <div class="logo-icon">&#8984;</div>
            <div class="logo-text">
                <span class="logo-title">TONS OF SKILLS</span>
                <span class="logo-subtitle">by intent solutions io</span>
            </div>
        </a>
        <button class="mobile-menu-toggle" aria-label="Toggle menu">
            <svg class="menu-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
            </svg>
            <svg class="close-icon" style="display: none;" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
            </svg>
        </button>
        <ul class="nav-links">
            <li><a href="/getting-started">Start Here</a></li>
            <li><a href="/explore">Explore</a></li>
            <li><a href="/explore?category=devops">DevOps</a></li>
            <li><a href="/skills">Skills</a></li>
            <li><a href="/learning">Learning</a></li>
            <li><a href="/#products">Products</a></li>
            <li><a href="/cowork">Cowork</a></li>
            <li><a href="https://github.com/jeremylongshore/claude-code-plugins" target="_blank" class="nav-cta">GitHub</a></li>
        </ul>
    </nav>

    <!-- Main Content -->
    <main>
        <slot />
    </main>

    <!-- Footer -->
    <footer>
        <div class="footer-content">
            <div class="footer-section">
                <h4>Resources</h4>
                <ul>
                    <li><a href="/getting-started">Getting Started</a></li>
                    <li><a href="/explore">Explore Plugins</a></li>
                    <li><a href="/skills">Agent Skills</a></li>
                    <li><a href="/learning">Learning Hub</a></li>
                    <li><a href="/research">Research</a></li>
                    <li><a href="/cowork">Cowork Downloads</a></li>
                    <li><a href="https://github.com/jeremylongshore/claude-code-plugins">GitHub</a></li>
                </ul>
            </div>
            <div class="footer-section">
                <h4>Featured</h4>
                <ul>
                    <li><a href="/plugins/gh-dash">gh-dash (PR Dashboard)</a></li>
                    <li><a href="/explore?category=devops">DevOps Plugins</a></li>
                    <li><a href="/explore?category=security">Security Plugins</a></li>
                    <li><a href="/explore?category=ai-ml-assistance">AI/ML Plugins</a></li>
                </ul>
            </div>
            <div class="footer-section">
                <h4>Community</h4>
                <ul>
                    <li><a href="https://github.com/sponsors/jeremylongshore">Sponsor</a></li>
                    <li><a href="https://buymeacoffee.com/jeremylongshore">Buy me a monster</a></li>
                    <li><a href="https://github.com/jeremylongshore/claude-code-plugins/discussions">Discussions</a></li>
                </ul>
            </div>
            <div class="footer-section">
                <h4>Legal</h4>
                <ul>
                    <li><a href="/privacy">Privacy</a></li>
                    <li><a href="/terms">Terms</a></li>
                    <li><a href="/acceptable-use">Acceptable Use</a></li>
                </ul>
            </div>
        </div>
        <div class="footer-bottom">
            <p>&copy; 2026 Claude Code Plugins · Open Source (MIT) · Built by <a href="https://intentsolutions.io" target="_blank">intent solutions io</a></p>
            <p style="margin-top: 0.5rem; font-size: 0.75rem;">Sponsored by <a href="https://nixtla.io" target="_blank">nixtla.io</a></p>
        </div>
    </footer>

    <!-- Mobile Menu Script -->
    <script is:inline>
        document.addEventListener('DOMContentLoaded', function() {
            var menuToggle = document.querySelector('.mobile-menu-toggle');
            var navLinks = document.querySelector('.nav-links');
            var menuIcon = document.querySelector('.menu-icon');
            var closeIcon = document.querySelector('.close-icon');

            if (menuToggle && navLinks) {
                menuToggle.addEventListener('click', function() {
                    navLinks.classList.toggle('active');
                    document.body.classList.toggle('menu-open');

                    if (navLinks.classList.contains('active')) {
                        menuIcon.style.display = 'none';
                        closeIcon.style.display = 'block';
                    } else {
                        menuIcon.style.display = 'block';
                        closeIcon.style.display = 'none';
                    }
                });

                // Close menu when clicking a link
                navLinks.querySelectorAll('a').forEach(function(link) {
                    link.addEventListener('click', function() {
                        navLinks.classList.remove('active');
                        document.body.classList.remove('menu-open');
                        menuIcon.style.display = 'block';
                        closeIcon.style.display = 'none';
                    });
                });

                // Close menu when clicking outside
                document.addEventListener('click', function(e) {
                    if (navLinks.classList.contains('active') &&
                        !navLinks.contains(e.target) &&
                        !menuToggle.contains(e.target)) {
                        navLinks.classList.remove('active');
                        document.body.classList.remove('menu-open');
                        menuIcon.style.display = 'block';
                        closeIcon.style.display = 'none';
                    }
                });
            }

            // Track outbound link clicks (nav + footer)
            document.querySelectorAll('nav a[target="_blank"], footer a[target="_blank"]').forEach(function(link) {
                link.addEventListener('click', function() {
                    if (window.trackEvent) {
                        window.trackEvent('outbound_click', {
                            url: link.href,
                            link_text: link.textContent.trim()
                        });
                    }
                });
            });
        });
    </script>
</body>
</html>
